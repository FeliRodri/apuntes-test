---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<div class="section-box">
  <h4 class="section-box__title">{title}</h4>
  <slot />
</div>

<style>
  .section-box {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 10px;
    padding: 14px 16px;
  }
  .section-box__title {
    font-size: 14px;
    font-weight: 600;
    color: var(--sl-color-white);
    margin: 0 0 8px;
  }
  /* listas dentro del box */
  .section-box :global(ul) {
    padding-left: 18px;
    font-size: 13px;
    color: var(--sl-color-gray-3);
    margin: 0;
  }
  .section-box :global(ul li) {
    margin-bottom: 4px;
  }
</style>
