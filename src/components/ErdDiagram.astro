---
import MermaidDiagram from "./MermaidDiagram.astro";

interface Props {
  diagram: string;
  id?: string;
}

const { diagram, id = "erd-default" } = Astro.props;

const erStyles = `
  .er.entityBox { stroke-width: 1.5px; }
  .er.entityLabel { font-weight: 700; fill: var(--sl-color-white) !important; }
  .er.attributeBox .label { fill: var(--sl-color-gray-2) !important; font-family: var(--sl-font-mono); }
  .er.attributeBox .type { fill: var(--sl-color-gray-3) !important; font-style: italic; font-size: 11px; }
`;
---

<MermaidDiagram
  id={id}
  diagram={diagram}
  type="erDiagram"
  errorLabel="diagrama ERD"
  diagramStyles={erStyles}
/>
