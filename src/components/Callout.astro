---
interface Props {
  type?: "info" | "tip" | "warn";
  title?: string;
}
const { type = "info", title } = Astro.props;
---

<div class={`callout callout--${type}`}>
  {title && <strong class="callout__title">{title}</strong>}
  <slot />
</div>

<style>
  .callout {
    border-left: 3px solid;
    padding: 10px 16px;
    border-radius: 0 8px 8px 0;
    margin: 16px 0;
    font-size: 14px;
    line-height: 1.6;
  }
  .callout__title {
    display: block;
    margin-bottom: 4px;
  }
  /* info → azul */
  .callout--info {
    border-color: var(--sl-color-blue);
    background: color-mix(in srgb, var(--sl-color-blue) 10%, transparent);
    color: var(--sl-color-white);
  }
  /* tip → verde */
  .callout--tip {
    border-color: var(--sl-color-green);
    background: color-mix(in srgb, var(--sl-color-green) 10%, transparent);
    color: var(--sl-color-white);
  }
  /* warn → amarillo */
  .callout--warn {
    border-color: var(--sl-color-orange);
    background: color-mix(in srgb, var(--sl-color-orange) 10%, transparent);
    color: var(--sl-color-white);
  }
</style>
